{
  "expo": {
    "name": "MyStreet",
    "slug": "mystreet",
    "version": "1.0.0",
    "description": "MyStreet — le marketplace de quartier. Vendre, louer et rendre service entre voisins à Lille et sa métropole.",
    "primaryColor": "#D8542B",
    "orientation": "portrait",
    "scheme": "mystreet",
    "userInterfaceStyle": "light",
    "icon": "./assets/images/favicon.png",
    "splash": {
      "image": "./assets/images/favicon.png",
      "resizeMode": "contain",
      "backgroundColor": "#D8542B"
    },
    "ios": {
      "supportsTablet": false,
      "buildNumber": "1",
      "bundleIdentifier": "com.mystreet.app",
      "icon": "./assets/images/favicon.png",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "MyStreet utilise ta position pour afficher les annonces autour de toi.",
        "NSCameraUsageDescription": "MyStreet utilise l'appareil photo pour ajouter des photos à tes annonces.",
        "NSPhotoLibraryUsageDescription": "MyStreet accède à tes photos pour les ajouter à tes annonces et ton profil.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 1,
      "package": "com.mystreet.app",
      "icon": "./assets/images/favicon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/favicon.png",
        "backgroundColor": "#D8542B"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0",
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MyStreet accède à tes photos pour les ajouter à tes annonces.",
          "cameraPermission": "MyStreet utilise l'appareil photo pour prendre des photos de tes annonces."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "MyStreet utilise ta position pour afficher les annonces autour de toi."
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "205917a5-c350-4815-8a1d-2f60f18e7336"
      }
    },
    "owner": "iheb1"
  }
}
